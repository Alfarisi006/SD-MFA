Markup=1.25
	~	Dmnl
	~	Markup adalah multiplier harga jual di atas biaya produksi.
		
		Market_Price = Production_Cost * Markup
		Markup 1.25 artinya:
		produsen mengambil margin 25% dari biaya produksi
		Markup bisa berubah sebagai parameter strategi bisnis tanpa memengaruhi \
		mass balance.
	|

Price sensitivity1=
	0.7
	~	Dmnl
	~		|

Profitability1=Market price1-Production cost1
	~	$/ton
	~		~	:SUPPLEMENTARY 
	|

Production cost=Base virgin cost * (1-Recycling share)
	~	$/ton
	~		|

Production cost1=Base virgin cost1 * (1 - Recycling share1)
	~	$/ton
	~		|

Price sensitivity=0.7
	~	Dmnl
	~	Seberapa kuat konsumen merespons perubahan harga.
		Masuk ke rumus:
		
		Demand_Index = 1 - (Price_Index - 1) * Price_Sensitivity
		
		0.1 = Konsumen tidak peduli harga
		0.7 = Konsumen sensitif harga
		>1 = Konsumen sangat sensitiif; sedikit perubahan harga menyebabkab \
		permintaan berubah drastis
	|

Profitability Recycling=Profitability*Recycling share
