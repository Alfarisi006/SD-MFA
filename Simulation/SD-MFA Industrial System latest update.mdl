	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

SDMFA material availability factor=SMOOTHI(SDMFA material availability target, SDMFA material availability adjustment time\
		, 1)
	~	Dmnl
	~	Material availability constraint inherited from DMFA. Values below 1 keep \
		SD-MFA use below the DMFA baseline while SD can exceed it through economic \
		rebound.
	|

